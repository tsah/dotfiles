#!/bin/bash

set -euo pipefail

agent="${1:-}"
state="${2:-}"

case "$agent" in
    claude|pi|codex) ;;
    *) exit 0 ;;
esac

case "$state" in
    running|working) state="working" ;;
    idle) state="idle" ;;
    done) state="done" ;;
    blocked|attention) state="blocked" ;;
    release|unknown) state="unknown" ;;
    *) exit 0 ;;
esac

pane="${TMUX_PANE:-}"
[[ -n "$pane" ]] || exit 0

state_dir="${XDG_RUNTIME_DIR:-/tmp}/alt-k-tui-$(id -u)/agent-state"
mkdir -p "$state_dir"
activity_dir="${XDG_STATE_HOME:-$HOME/.local/state}/alt-k-tui/activity"
activity_path=$(tmux display-message -p -t "$pane" '#{pane_current_path}' 2>/dev/null || pwd -P)

# Consume hook stdin so callers that provide JSON never block on a full pipe.
hook_input=$(cat 2>/dev/null || true)

AGENT="$agent" STATE="$state" PANE="$pane" HOOK_INPUT="$hook_input" STATE_DIR="$state_dir" ACTIVITY_DIR="$activity_dir" ACTIVITY_PATH="$activity_path" python3 - <<'PY'
import hashlib
import json
import os
import pathlib
import re
import time

agent = os.environ.get("AGENT", "")
state = os.environ.get("STATE", "")
pane = os.environ.get("PANE", "")
state_dir = pathlib.Path(os.environ.get("STATE_DIR", ""))
hook_input = os.environ.get("HOOK_INPUT", "")
activity_dir = pathlib.Path(os.environ.get("ACTIVITY_DIR", ""))
activity_path = pathlib.Path(os.environ.get("ACTIVITY_PATH", "")).resolve()

if not agent or not state or not pane or not state_dir:
    raise SystemExit(0)

payload = {}
if hook_input.strip():
    try:
        payload = json.loads(hook_input)
    except Exception:
        payload = {}

safe_pane = re.sub(r"[^A-Za-z0-9_.%-]", "_", pane)
target = state_dir / f"{safe_pane}.json"
tmp = state_dir / f"{safe_pane}.{os.getpid()}.tmp"
record = {
    "agent": agent,
    "state": state,
    "pane": pane,
    "updatedAt": int(time.time() * 1000),
    "hookEvent": payload.get("hook_event_name") if isinstance(payload, dict) else None,
}
tmp.write_text(json.dumps(record), encoding="utf-8")
tmp.replace(target)

if activity_dir and activity_path:
    activity_dir.mkdir(parents=True, exist_ok=True)
    activity_target = activity_dir / f"{hashlib.sha256(str(activity_path).encode()).hexdigest()}-agent.json"
    activity_tmp = activity_dir / f"{activity_target.name}.{os.getpid()}.tmp"
    activity_tmp.write_text(json.dumps({"path": str(activity_path), "source": "agent", "updatedAt": record["updatedAt"]}), encoding="utf-8")
    activity_tmp.replace(activity_target)
PY
