#!/bin/bash
# Open diffview file history
# Works from shell (launches nvim) or from nvim terminal (sends command to parent)
# Usage: vdh [file]

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Not in a git repository" >&2
    exit 1
fi

if [[ -n "$NVIM" ]]; then
    nvim --server "$NVIM" --remote-send "<C-\\><C-n>:Vdh $1<CR>"
else
    exec nvim -c "Vdh $1"
fi
