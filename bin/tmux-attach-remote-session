#!/bin/bash

set -euo pipefail

usage() {
    echo "Usage: $0 <host> <session-name>"
}

if [[ $# -ne 2 ]]; then
    usage >&2
    exit 1
fi

HOST_NAME="$1"
SESSION_NAME="$2"

printf -v REMOTE_COMMAND 'tmux attach-session -t %q' "$SESSION_NAME"

if [[ -n "${TMUX:-}" ]]; then
    if command -v ghostty >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
        ghostty +new-window -e ssh -t "$HOST_NAME" "$REMOTE_COMMAND" >/dev/null 2>&1 &
        disown || true
        exit 0
    fi

    printf -v LOCAL_COMMAND 'ssh -t %q %q' "$HOST_NAME" "$REMOTE_COMMAND"
    tmux new-window -n "ssh:${HOST_NAME}" "$LOCAL_COMMAND" >/dev/null 2>&1 || {
        echo "Failed to open remote session in a new tmux window." >&2
        exit 1
    }
    exit 0
fi

exec ssh -t "$HOST_NAME" "$REMOTE_COMMAND"
