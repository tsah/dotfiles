#!/bin/bash

set -euo pipefail

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
if [[ -r "$SCRIPT_DIR/lib/bootstrap-path.sh" ]]; then
    # Ensure ~/.bun/bin and other user tool dirs are available from tmux popups.
    # shellcheck source=/dev/null
    . "$SCRIPT_DIR/lib/bootstrap-path.sh"
fi

if ! command -v bun >/dev/null 2>&1; then
    echo "workspace-picker requires bun" >&2; exit 1
fi

cd "${DOTFILES_DIR:-$HOME/dotfiles}/alt-k-tui" || exit 1

tmux set-option -gq @alt_k_tui_open 1
trap 'tmux set-option -gu @alt_k_tui_open 2>/dev/null || true' EXIT

STATE_DIR="${XDG_RUNTIME_DIR:-/tmp}/alt-k-tui-$(id -u)"
PID_FILE="$STATE_DIR/server.pid"
CACHE_FILE="$STATE_DIR/state.json"
LOG_FILE="$STATE_DIR/server.log"
SOCKET_FILE="$STATE_DIR/server.tmux-socket"
CURRENT_TMUX_SOCKET=${TMUX%%,*}

server_running() {
    local pid=""
    [[ -r "$PID_FILE" ]] || return 1
    pid=$(<"$PID_FILE")
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    # A cache process inherited from another tmux socket cannot observe this
    # client's sessions or agents (common after isolated QA runs).
    [[ -r "$SOCKET_FILE" ]] || return 1
    [[ "$(<"$SOCKET_FILE")" == "$CURRENT_TMUX_SOCKET" ]]
}

mkdir -p "$STATE_DIR"
if ! server_running; then
    if [[ -r "$PID_FILE" ]]; then
        old_pid=$(<"$PID_FILE")
        [[ "$old_pid" =~ ^[0-9]+$ ]] && kill "$old_pid" 2>/dev/null || true
    fi
    rm -f "$PID_FILE" "$CACHE_FILE"
    printf '%s\n' "$CURRENT_TMUX_SOCKET" > "$SOCKET_FILE"
    nohup bun src/main.tsx --server >>"$LOG_FILE" 2>&1 &
fi

for _ in {1..20}; do
    [[ -s "$CACHE_FILE" ]] && break
    sleep 0.05
done

bun src/main.tsx
