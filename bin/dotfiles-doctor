#!/bin/bash

set -u

checks=0
warnings=0
failures=0

supports_color() {
    [[ -t 1 && -z "${NO_COLOR:-}" ]]
}

if supports_color; then
    green=$'\033[32m'
    yellow=$'\033[33m'
    red=$'\033[31m'
    reset=$'\033[0m'
else
    green=""
    yellow=""
    red=""
    reset=""
fi

ok() {
    checks=$((checks + 1))
    printf '%sOK%s   %s\n' "$green" "$reset" "$1"
}

warn() {
    checks=$((checks + 1))
    warnings=$((warnings + 1))
    printf '%sWARN%s %s\n' "$yellow" "$reset" "$1"
}

fail() {
    checks=$((checks + 1))
    failures=$((failures + 1))
    printf '%sFAIL%s %s\n' "$red" "$reset" "$1"
}

check_cmd() {
    local cmd="$1"
    local level="${2:-warn}"

    if command -v "$cmd" >/dev/null 2>&1; then
        ok "command available: $cmd"
    elif [[ "$level" == "critical" ]]; then
        fail "missing critical command: $cmd"
    else
        warn "missing optional command: $cmd"
    fi
}

check_link() {
    local link="$1"
    local expected_prefix="$2"
    local target
    local resolved

    if [[ ! -e "$link" && ! -L "$link" ]]; then
        fail "missing link: $link"
        return
    fi

    if [[ ! -L "$link" ]]; then
        fail "not a symlink: $link"
        return
    fi

    target=$(readlink "$link")
    if [[ "$target" == /* ]]; then
        resolved="$target"
    else
        resolved="$(dirname "$link")/$target"
    fi
    resolved=$(realpath -m "$resolved")

    if [[ "$resolved" == "$expected_prefix" || "$resolved" == "$expected_prefix"/* ]]; then
        ok "link target valid: $link -> $target"
    else
        fail "wrong target: $link -> $target (expected under $expected_prefix)"
    fi
}

check_skill_links() {
    local dir="$1"
    local link target resolved

    if [[ -L "$dir" && ! -e "$dir" ]]; then
        fail "broken skills directory link: $dir -> $(readlink "$dir")"
        return
    fi

    if [[ ! -d "$dir" ]]; then
        warn "missing skills directory: $dir"
        return
    fi

    for link in "$dir"/*; do
        [[ -L "$link" ]] || continue
        target=$(readlink "$link")

        if [[ ! -e "$link" ]]; then
            fail "broken skill link: $link -> $target"
        elif [[ ! -d "$link" ]]; then
            fail "skill link is not a directory: $link -> $target"
        elif [[ ! -f "$link/SKILL.md" ]]; then
            fail "skill link missing SKILL.md: $link -> $target"
        else
            ok "skill link valid: $link -> $target"
        fi
    done
}

check_command_links() {
    local dir="$1"
    local link target

    if [[ -L "$dir" && ! -e "$dir" ]]; then
        fail "broken commands directory link: $dir -> $(readlink "$dir")"
        return
    fi

    if [[ ! -d "$dir" ]]; then
        warn "missing commands directory: $dir"
        return
    fi

    for link in "$dir"/*; do
        [[ -L "$link" ]] || continue
        target=$(readlink "$link")

        if [[ -e "$link" ]]; then
            ok "command link valid: $link -> $target"
        else
            fail "broken command link: $link -> $target"
        fi
    done
}

check_opencode_plugins() {
    local config="$1"
    local plugin path

    if [[ ! -f "$config" ]]; then
        warn "missing opencode config: $config"
        return
    fi

    while IFS= read -r plugin; do
        path="${plugin#file://}"
        if [[ -e "$path" ]]; then
            ok "opencode plugin exists: $path"
        else
            fail "missing opencode plugin: $path"
        fi
    done < <(grep -o 'file://[^"]*' "$config")
}

is_desktop_profile() {
    case "${DOTFILES_PROFILE:-}" in
        omarchy|desktop|laptop)
            return 0
            ;;
        server|dev-server|headless)
            return 1
            ;;
    esac

    command -v hyprctl >/dev/null 2>&1
}

dotfiles_root="$(realpath -m "$HOME/dotfiles")"

printf 'Dotfiles doctor\n'
printf 'Repository: %s\n\n' "$dotfiles_root"

check_cmd git critical
check_cmd tmux
check_cmd nvim
check_cmd opencode

check_link "$HOME/.config/opencode/opencode.json" "$dotfiles_root"
check_link "$HOME/.config/nvim" "$dotfiles_root"
if is_desktop_profile; then
    check_link "$HOME/.config/hypr" "$dotfiles_root"
else
    warn "skipping Hyprland link check on server/headless profile"
fi
check_link "$HOME/.tmux.conf" "$dotfiles_root"

check_skill_links "$HOME/.claude/skills"
check_skill_links "$HOME/.agents/skills"

check_command_links "$HOME/.claude/commands"
check_command_links "$HOME/.config/opencode/command"
check_command_links "$HOME/.config/opencode/commands"

check_opencode_plugins "$dotfiles_root/opencode.json"

printf '\nSummary: %d checks, %d warnings, %d failures\n' "$checks" "$warnings" "$failures"

if ((failures > 0)); then
    if is_desktop_profile; then
        printf 'Run ./install-omarchy.sh from %s to refresh desktop symlinks.\n' "$dotfiles_root"
    else
        printf 'Run ./install-server.sh from %s to refresh server symlinks.\n' "$dotfiles_root"
    fi
    exit 1
fi

exit 0
