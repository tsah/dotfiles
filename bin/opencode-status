#!/usr/bin/env python3

import json
import os
import shutil
import subprocess
import argparse
import time
import urllib.error
import urllib.parse
import urllib.request
from concurrent.futures import ThreadPoolExecutor, as_completed
from collections import defaultdict
from datetime import datetime


HOME = os.path.expanduser("~")
SESSION_HTTP_TIMEOUT = 1
MESSAGE_HTTP_TIMEOUT = 0.5
TSV_CACHE_TTL_SECONDS = 8


RESET = "\033[0m"
COLORS = {
    "header": "\033[1;37m",
    "directory": "\033[36m",
    "title": "\033[90m",
    "age": "\033[90m",
    "generating": "\033[33m",
    "waiting question": "\033[36m",
    "tool running": "\033[35m",
    "done": "\033[32m",
    "starting": "\033[34m",
    "unknown": "\033[90m",
}


def read_text(path):
    try:
        with open(path, "r", encoding="utf-8", errors="ignore") as f:
            return f.read()
    except OSError:
        return ""


def read_cmdline(pid):
    raw = read_text(f"/proc/{pid}/cmdline")
    if not raw:
        return []
    parts = [p for p in raw.split("\x00") if p]
    return parts


def has_color():
    return os.isatty(1) and os.environ.get("NO_COLOR") is None


def colorize(text, key):
    if not has_color():
        return text
    return f"{COLORS.get(key, '')}{text}{RESET}"


def shorten_path(path):
    if path == HOME:
        return "~"
    if path.startswith(HOME + "/"):
        return "~" + path[len(HOME) :]
    return path


def extract_port(cmdline):
    for i, arg in enumerate(cmdline):
        if arg == "--port" and i + 1 < len(cmdline):
            try:
                return int(cmdline[i + 1])
            except ValueError:
                pass
        if arg.startswith("--port="):
            try:
                return int(arg.split("=", 1)[1])
            except ValueError:
                pass
    return None


def api_get(port, path, timeout):
    url = f"http://127.0.0.1:{port}{path}"
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read())
    except (urllib.error.URLError, json.JSONDecodeError, OSError, ValueError):
        return None


def get_opencode_pids():
    pids = []

    try:
        result = subprocess.run(
            ["pgrep", "-x", "opencode"],
            check=False,
            capture_output=True,
            text=True,
        )
        if result.returncode == 0:
            for line in result.stdout.splitlines():
                line = line.strip()
                if line.isdigit():
                    pids.append(line)
    except OSError:
        pass

    if pids:
        return pids

    for entry in os.listdir("/proc"):
        if not entry.isdigit():
            continue
        if is_opencode_process(entry):
            pids.append(entry)

    return pids



def is_interactive_instance(cmdline):
    if not cmdline:
        return False

    if "--stdio" in cmdline:
        return False

    if len(cmdline) > 1:
        subcommands = {
            "completion",
            "acp",
            "mcp",
            "attach",
            "run",
            "debug",
            "auth",
            "agent",
            "upgrade",
            "uninstall",
            "serve",
            "web",
            "models",
            "stats",
            "export",
            "import",
            "github",
            "pr",
            "session",
            "db",
            "x",
        }
        second = cmdline[1]
        if second in subcommands:
            return False
        if second.endswith(".js"):
            return False

    return True


def is_opencode_process(pid):
    comm = read_text(f"/proc/{pid}/comm").strip()
    return comm == "opencode"


def infer_status(last_msg, is_run_mode):
    """Derive status from the latest API message. Returns (status, detail)."""
    if not last_msg:
        return "starting", ""

    info = last_msg.get("info", {})
    role = info.get("role")
    time_obj = info.get("time") or {}
    completed = time_obj.get("completed")

    # Check for a running tool in the message parts.
    for part in reversed(last_msg.get("parts", [])):
        state = part.get("state") or {}
        if part.get("type") == "tool" and state.get("status") == "running":
            tool_name = part.get("tool", "tool")
            if tool_name == "question":
                return "waiting question", tool_name
            return "tool running", tool_name

    if role == "user":
        return "generating", "awaiting assistant"

    if role == "assistant":
        if completed:
            if is_run_mode:
                return "done", "run mode"
            return "done", "awaiting next task"
        return "generating", "assistant thinking"

    return "unknown", ""


def status_rank(status):
    order = {
        "tool running": 0,
        "waiting question": 1,
        "generating": 2,
        "starting": 3,
        "done": 4,
        "unknown": 5,
    }
    return order.get(status, 99)


def format_age(epoch_ms):
    if not epoch_ms:
        return "-"
    seconds = max(0, int((datetime.now().timestamp() * 1000 - epoch_ms) / 1000))
    if seconds < 60:
        return f"{seconds}s"
    minutes = seconds // 60
    if minutes < 60:
        return f"{minutes}m"
    hours = minutes // 60
    return f"{hours}h"


def process_age_seconds(start_ticks, clock_ticks_per_second, uptime_seconds):
    if not start_ticks or not clock_ticks_per_second or uptime_seconds is None:
        return None

    try:
        started_at = start_ticks / float(clock_ticks_per_second)
        age = uptime_seconds - started_at
        if age < 0:
            return 0
        return int(age)
    except (TypeError, ValueError, ZeroDivisionError):
        return None


def system_uptime_seconds():
    try:
        with open("/proc/uptime", "r", encoding="utf-8", errors="ignore") as f:
            first = f.read().strip().split()[0]
        return float(first)
    except (OSError, IndexError, ValueError):
        return None


def session_lookup_directories(directory):
    dirs = []

    def add(path):
        if path and path not in dirs:
            dirs.append(path)

    path = directory.rstrip("/")
    add(path)

    parent = os.path.dirname(path)
    base = os.path.basename(path)
    repo = os.path.basename(parent)
    grandparent = os.path.dirname(parent)

    if base and repo and grandparent and grandparent != parent:
        add(os.path.join(grandparent, f"{repo}-{base}"))
        add(os.path.join(grandparent, f"{repo}-next", base))

    if base == "master" and parent:
        add(parent)

    return dirs


def truncate_text(text, max_len=56):
    if text is None:
        return ""
    text = str(text).strip().replace("\n", " ")
    if max_len <= 0:
        return ""
    if len(text) <= max_len:
        return text
    if max_len <= 3:
        return text[:max_len]
    return text[: max_len - 3] + "..."


def compute_column_widths(rows):
    term_width = shutil.get_terminal_size((120, 20)).columns
    status_width = max(6, *(len(r["status"]) for r in rows))
    age_width = 3
    separators = 6

    remaining = term_width - status_width - age_width - separators
    if remaining < 12:
        remaining = 12

    min_dir = 10
    min_title = 0

    max_dir_len = max(9, *(len(r["directory"]) for r in rows))
    preferred_dir = min(max_dir_len, max(min_dir, int(remaining * 0.55)))
    dir_width = max(min_dir, min(preferred_dir, remaining - min_title))
    title_width = max(min_title, remaining - dir_width)

    return dir_width, status_width, title_width


def tty_for_pid(pid):
    try:
        tty_path = os.readlink(f"/proc/{pid}/fd/0")
    except OSError:
        return ""

    if tty_path.startswith("/dev/"):
        return tty_path

    return ""


def process_start_ticks(pid):
    stat = read_text(f"/proc/{pid}/stat")
    if not stat:
        return 0
    try:
        rest = stat.rsplit(") ", 1)[1].split()
        return int(rest[19])
    except (IndexError, ValueError):
        return 0


def tmux_tty_lookup():
    lookup = {}
    if not shutil.which("tmux"):
        return lookup

    try:
        result = subprocess.run(
            [
                "tmux",
                "list-panes",
                "-a",
                "-F",
                "#{pane_tty}\t#{session_name}\t#{session_name}:#{window_index}.#{pane_index}",
            ],
            check=False,
            capture_output=True,
            text=True,
        )
    except OSError:
        return lookup

    if result.returncode != 0:
        return lookup

    for line in result.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) != 3:
            continue
        pane_tty, session_name, pane_target = parts
        lookup[pane_tty] = {
            "session": session_name,
            "pane": pane_target,
        }

    return lookup


def main():
    parser = argparse.ArgumentParser(add_help=True)
    parser.add_argument("--tsv", action="store_true", help="output tab-separated rows")
    parser.add_argument("--no-cache", action="store_true", help="disable short-lived TSV cache")
    args = parser.parse_args()

    cache_path = f"/tmp/opencode-status-{os.getuid()}.tsv"
    cache_ttl_seconds = TSV_CACHE_TTL_SECONDS

    if args.tsv and not args.no_cache:
        try:
            st = os.stat(cache_path)
            if time.time() - st.st_mtime <= cache_ttl_seconds:
                cached = read_text(cache_path)
                if cached:
                    print(cached, end="")
                    return
        except OSError:
            pass

    pids = get_opencode_pids()

    if not pids:
        print("No running opencode instances.")
        return

    instances = []
    tty_lookup = tmux_tty_lookup()

    for pid in pids:
        cmdline = read_cmdline(pid)
        if not is_interactive_instance(cmdline):
            continue

        try:
            cwd = os.readlink(f"/proc/{pid}/cwd")
        except OSError:
            continue

        is_run_mode = len(cmdline) > 1 and cmdline[1] == "run"
        session_name = ""
        pane_target = ""

        tty = tty_for_pid(pid)
        if tty and tty in tty_lookup:
            session_name = tty_lookup[tty]["session"]
            pane_target = tty_lookup[tty]["pane"]

        instances.append(
            {
                "pid": pid,
                "cwd": cwd,
                "port": extract_port(cmdline),
                "is_run_mode": is_run_mode,
                "session_name": session_name,
                "pane_target": pane_target,
                "session_id": "",
                "start_ticks": process_start_ticks(pid),
            }
        )

    if not instances:
        print("No running interactive opencode instances.")
        return

    # Fetch session lists per port (each port serves one project)
    port_sessions = {}
    session_titles = {}
    session_updated_times = {}
    scoped_session_cache = {}

    unique_ports = sorted({inst["port"] for inst in instances if inst["port"]})
    if unique_ports:
        workers = min(8, len(unique_ports))
        with ThreadPoolExecutor(max_workers=workers) as executor:
            future_to_port = {
                executor.submit(
                    api_get, port, "/session?limit=1000", SESSION_HTTP_TIMEOUT
                ): port
                for port in unique_ports
            }

            for future in as_completed(future_to_port):
                port = future_to_port[future]
                try:
                    sessions = future.result()
                except Exception:
                    sessions = None

                if not isinstance(sessions, list):
                    sessions = []

                port_sessions[port] = sessions
                for s in sessions:
                    sid = s.get("id")
                    if sid:
                        session_titles[sid] = s.get("title", "")
                        session_updated_times[sid] = (
                            s.get("time", {}).get("updated", 0) or 0
                        )

    # Resolve session IDs — always pick the most recently active
    # session for the directory rather than trusting the cmdline -s
    # flag, which goes stale when the user switches sessions in the TUI.
    by_cwd = defaultdict(list)
    for inst in instances:
        by_cwd[inst["cwd"]].append(inst)

    for cwd, cwd_instances in by_cwd.items():
        sessions = []
        for inst in cwd_instances:
            if inst["port"] and inst["port"] in port_sessions:
                sessions = port_sessions[inst["port"]]
                break

        lookup_dirs = session_lookup_directories(cwd)

        candidate_by_id = {}

        def add_candidates(session_rows):
            for s in session_rows:
                if s.get("directory") not in lookup_dirs:
                    continue
                if s.get("time", {}).get("archived"):
                    continue

                sid = s.get("id")
                if not sid:
                    continue

                candidate_by_id[sid] = s
                session_titles[sid] = s.get("title", "")
                session_updated_times[sid] = (
                    s.get("time", {}).get("updated", 0) or 0
                )

        add_candidates(sessions)

        if not candidate_by_id:
            for inst in cwd_instances:
                port = inst.get("port")
                if not port:
                    continue

                for lookup_dir in lookup_dirs:
                    cache_key = (port, lookup_dir)
                    if cache_key not in scoped_session_cache:
                        encoded_dir = urllib.parse.quote(lookup_dir, safe="")
                        scoped = api_get(
                            port,
                            f"/session?directory={encoded_dir}&limit=200",
                            SESSION_HTTP_TIMEOUT,
                        )
                        if not isinstance(scoped, list):
                            scoped = []
                        scoped_session_cache[cache_key] = scoped

                    add_candidates(scoped_session_cache[cache_key])

        candidates = sorted(
            candidate_by_id.values(),
            key=lambda s: s.get("time", {}).get("updated", 0),
            reverse=True,
        )

        candidate_ids = [s["id"] for s in candidates if s.get("id")]

        # All instances need resolution (session_id starts empty).
        # Sort newest-first so the most recent instance gets the
        # most recently updated session.
        unresolved = list(cwd_instances)
        unresolved.sort(key=lambda i: i["start_ticks"], reverse=True)

        for idx, inst in enumerate(unresolved):
            if idx < len(candidate_ids):
                inst["session_id"] = candidate_ids[idx]
            elif candidates:
                inst["session_id"] = candidates[0].get("id", "")

    grouped = defaultdict(list)
    now_ms = int(datetime.now().timestamp() * 1000)
    clock_ticks = os.sysconf(os.sysconf_names.get("SC_CLK_TCK", "SC_CLK_TCK"))
    uptime_seconds = system_uptime_seconds()

    message_requests = {}
    for inst in instances:
        sid = inst["session_id"]
        port = inst["port"]
        if not port or not sid:
            continue
        message_key = f"{port}:{sid}"
        message_requests[message_key] = (port, sid)

    message_cache = {}
    if message_requests:
        workers = min(8, len(message_requests))
        with ThreadPoolExecutor(max_workers=workers) as executor:
            future_to_key = {
                executor.submit(
                    api_get,
                    port,
                    f"/session/{sid}/message?limit=1",
                    MESSAGE_HTTP_TIMEOUT,
                ): key
                for key, (port, sid) in message_requests.items()
            }

            for future in as_completed(future_to_key):
                key = future_to_key[future]
                try:
                    message_cache[key] = future.result()
                except Exception:
                    message_cache[key] = None

    for inst in instances:
        pid = inst["pid"]
        cwd = inst["cwd"]
        session_id = inst["session_id"]
        port = inst["port"]
        status = "starting"
        title = session_titles.get(session_id, "")
        age = "-"
        proc_age_seconds = process_age_seconds(inst.get("start_ticks", 0), clock_ticks, uptime_seconds)

        if port and session_id:
            message_key = f"{port}:{session_id}"
            messages = message_cache.get(message_key)
            if isinstance(messages, list) and messages:
                last_msg = messages[-1]
                msg_time = (
                    last_msg.get("info", {}).get("time", {}).get("created", 0)
                )
                status, _detail = infer_status(last_msg, inst["is_run_mode"])
                age = format_age(msg_time)
            else:
                status = "unknown"
                age = format_age(session_updated_times.get(session_id, 0))
        else:
            status = "unknown"
            if proc_age_seconds is not None:
                age = format_age(now_ms - (proc_age_seconds * 1000))

        grouped[cwd].append(
            (
                status,
                title,
                pid,
                age,
                inst["session_name"],
                inst["pane_target"],
            )
        )

    rows = []
    for cwd, entries in grouped.items():
        short_dir = shorten_path(cwd)
        sorted_entries = sorted(entries, key=lambda e: (status_rank(e[0]), int(e[2])))
        total = len(sorted_entries)

        for idx, entry in enumerate(sorted_entries, start=1):
            status, title, pid, age, session_name, pane_target = entry
            label = short_dir
            if total > 1:
                label = f"{short_dir} ({idx})"

            rows.append(
                {
                    "directory": label,
                    "status": status,
                    "title": title,
                    "age": age,
                    "session": session_name,
                    "pane": pane_target,
                    "pid": pid,
                }
            )

    rows.sort(key=lambda r: r["directory"])

    if args.tsv:
        lines = []
        for row in rows:
            directory = row["directory"].replace("\t", " ")
            status = row["status"].replace("\t", " ")
            title = (row["title"] or "").replace("\t", " ").replace("\n", " ")
            age = row["age"].replace("\t", " ")
            session = (row["session"] or "").replace("\t", " ")
            pane = (row["pane"] or "").replace("\t", " ")
            pid = str(row["pid"])
            lines.append("\t".join([directory, status, title, age, session, pane, pid]))

        output = "\n".join(lines)
        if output:
            output += "\n"
        print(output, end="")

        if not args.no_cache:
            try:
                with open(cache_path, "w", encoding="utf-8") as f:
                    f.write(output)
            except OSError:
                pass
        return

    dir_width, status_width, title_width = compute_column_widths(rows)

    for row in rows:
        row["directory"] = truncate_text(row["directory"], dir_width)
        row["title"] = truncate_text(row["title"], title_width)

    header = (
        f"{'DIRECTORY'.ljust(dir_width)}  "
        f"{'STATUS'.ljust(status_width)}  "
        f"{'TITLE'.ljust(title_width)}  "
        f"AGE"
    )
    print(colorize(header, "header"))

    for row in rows:
        print(
            f"{colorize(row['directory'].ljust(dir_width), 'directory')}  "
            f"{colorize(row['status'].ljust(status_width), row['status'])}  "
            f"{colorize(row['title'].ljust(title_width), 'title')}  "
            f"{colorize(row['age'].rjust(3), 'age')}"
        )


if __name__ == "__main__":
    main()
