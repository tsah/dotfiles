#!/bin/bash
set -euo pipefail
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
DRY_RUN=false
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=true
[[ -n "${TMUX:-}" ]] || { echo "Must run inside the agent's tmux session" >&2; exit 1; }
identity=$($SCRIPT_DIR/dotfiles-workflow identity)
readarray -t fields < <(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d["path"]); print(d["branch"]); print(d["commonDir"])' <<<"$identity")
worktree=${fields[0]}; branch=${fields[1]}; common=${fields[2]}
session=$(tmux display-message -p '#S')
tagged=$(tmux show-option -qv -t "$session" @dotfiles_worktree_path)
[[ -n "$tagged" && "$(realpath "$tagged")" == "$worktree" ]] || { echo "Session is not tagged for canonical worktree $worktree" >&2; exit 1; }
[[ "$(realpath "$(tmux show-option -qv -t "$session" @dotfiles_git_common_dir)")" == "$common" ]] || { echo "Repository identity mismatch" >&2; exit 1; }
[[ "$branch" != "detached" ]] || { echo "Refusing detached HEAD" >&2; exit 1; }
status=$(git -C "$worktree" status --porcelain)
upstream=$(git -C "$worktree" rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || true)
unpushed=true
if [[ -n "$upstream" ]] && git -C "$worktree" merge-base --is-ancestor HEAD "$upstream"; then unpushed=false; fi
unsafe=false; [[ -n "$status" || "$unpushed" == true ]] && unsafe=true
printf 'Self destruct target:\n  Worktree: %s\n  Branch: %s\n  Session: %s\n' "$worktree" "$branch" "$session"
if [[ "$unsafe" == true ]]; then
  [[ -t 0 ]] || { echo "Unsafe state requires an interactive human confirmation" >&2; exit 1; }
  printf "Dirty, untracked, or unpushed state detected. Type branch '%s' to destroy: " "$branch"
  read -r confirmation; [[ "$confirmation" == "$branch" ]] || { echo "Aborted."; exit 1; }
fi
[[ "$DRY_RUN" == false ]] || { echo "Dry run only; no changes made."; exit 0; }
# Worktrunk remains the authority for safe worktree teardown.
remove_status=0
wt -C "$worktree" -y remove --foreground --force --no-delete-branch || remove_status=$?
if ! worktree_list=$(git --git-dir="$common" worktree list --porcelain); then
  echo "Unable to verify worktree removal; preserving tmux session" >&2
  exit 1
fi
if grep -Fqx "worktree $worktree" <<<"$worktree_list"; then
  echo "Worktree removal failed; preserving tmux session (wt exited $remove_status)" >&2
  [[ "$remove_status" -ne 0 ]] || remove_status=1
  exit "$remove_status"
fi
exec tmux kill-session -t "$session"
