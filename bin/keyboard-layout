#!/bin/bash

if [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
    layout=$(hyprctl devices -j | jq -r '.keyboards[] | select(.main == true) | .active_keymap')
    case "$layout" in
        *"English"*|*"US"*) echo "us" ;;
        *"Hebrew"*|*"Israeli"*) echo "il" ;;
        *) echo "${layout:0:2}" ;;
    esac
else
    echo "n/a"
fi