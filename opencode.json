{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "plan",
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      }
    }
  },
  "tools": {
    "linear_*": false
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4",
      "color": "#9B59B6"
    },
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.3-codex",
      "color": "#3498DB"
    },
    "fast": {
      "description": "Fast build agent",
      "mode": "primary",
      "model": "openai/gpt-5.3-codex-spark",
      "color": "#2ECC71"
    },
    "linear-agent": {
      "description": "Manages Linear issues, projects, and workflow tasks",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "linear_*": true
      }
    }
  }
}
