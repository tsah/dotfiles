{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "build",
  "command": {
    "plannotator-last": {
      "description": "Annotate the last assistant message",
      "template": "Open Plannotator for the last assistant message in this OpenCode session."
    }
  },
  "plugin": [
    "file:///home/tsah/dotfiles/opencode/plugins/plannotator-last-compat.js",
    [
      "@ishaksebsib/opencode-tree",
      {
        "storageScope": "global"
      }
    ]
  ],
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    }
  },
  "lsp": false,
  "tools": {
    "linear_*": false
  },
  "permission": {
    "linear_*": "deny",
    "external_directory": {
      "/**": "allow"
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.6-sol",
      "variant": "low",
      "color": "#3498DB"
    }
  }
}
