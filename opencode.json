{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "default_agent": "build",
  "plugin": [
    [
      "@plannotator/opencode@latest",
      {
        "workflow": "manual"
      }
    ],
    [
      "@ishaksebsib/opencode-tree",
      {
        "storageScope": "global"
      }
    ]
  ],
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:LINEAR_API_KEY}"
      }
    }
  },
  "lsp": false,
  "tools": {
    "linear_*": false
  },
  "permission": {
    "linear_*": "deny",
    "external_directory": {
      "/**": "allow"
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "color": "#9B59B6"
    },
    "build": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "variant": "low",
      "color": "#3498DB"
    },
    "fast": {
      "description": "Fast build agent",
      "mode": "primary",
      "model": "openai/gpt-5.5-fast",
      "color": "#2ECC71"
    }
  }
}
